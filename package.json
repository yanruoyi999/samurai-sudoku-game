{
  "name": "samurai-sudoku",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "prebuild": "pnpm test:indexnow && pnpm build-index && pnpm validate-puzzles && pnpm validate-pdf-packs",
    "generate-puzzles": "tsx scripts/puzzles/generate.ts",
    "build-index": "tsx scripts/puzzles/build-index.ts",
    "generate-pwa-assets": "tsx scripts/generate-pwa-assets.ts",
    "generate-pdf-packs": "python3 scripts/generate-pdf-packs.py",
    "validate-pdf-packs": "tsx scripts/validate-pdf-packs.ts",
    "validate-puzzles": "tsx scripts/puzzles/validate-all.ts",
    "check-difficulty": "tsx scripts/puzzles/check-difficulty.ts",
    "audit:internal-links": "tsx scripts/audit-internal-links.ts",
    "audit:page-quality": "tsx scripts/page-quality-audit.ts",
    "test": "vitest run",
    "test:sudoku": "vitest run lib/sudoku",
    "test:indexnow": "node --test scripts/submit-indexnow.node-test.mjs",
    "seo:indexnow": "node scripts/submit-indexnow.mjs"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "10.2.9",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.0",
    "next": "^15.5.19",
    "next-intl": "^4.13.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.5.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/ui": "^2.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "webpack": "^5.107.2"
  },
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "overrides": {
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "minimatch@<3.1.4": "3.1.4",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@<8.5.10": "8.5.10",
      "serialize-javascript@<7.0.5": "7.0.5"
    }
  }
}
