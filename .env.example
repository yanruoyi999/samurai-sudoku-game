# Application URL used for sitemap, canonical URLs, and Open Graph URLs.
NEXT_PUBLIC_APP_URL="https://www.samuraisudoku.net"

# Google Analytics 4 only loads when a site-specific measurement ID is configured.
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_SUDOKU_GA_ID=""
# Backward-compatible aliases are also supported by the app:
# NEXT_PUBLIC_SUDOKU_GA4_MEASUREMENT_ID=""
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=""

# Microsoft Clarity only loads after visitor consent.
NEXT_PUBLIC_SUDOKU_CLARITY_PROJECT_ID=""

# Typeform feedback/support opens only when a form URL or form ID is configured.
# Prefer the full URL if you use custom Typeform share settings.
NEXT_PUBLIC_SUDOKU_TYPEFORM_FORM_ID=""
# NEXT_PUBLIC_SUDOKU_TYPEFORM_URL="https://form.typeform.com/to/your-form-id"

# Fill this only after Google AdSense approval. It powers /ads.txt.
# Example: pub-0000000000000000
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=""
# Backward-compatible aliases are also supported:
# NEXT_PUBLIC_GOOGLE_ADSENSE_PUBLISHER_ID=""
# GOOGLE_ADSENSE_PUBLISHER_ID=""
